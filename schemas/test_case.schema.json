{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sukwoo0711-maker/trace32-agent-control-guide/schemas/test_case.schema.json",
  "title": "TRACE32 MCU Test Case",
  "description": "A structured, evidence-bearing MCU test case evaluated into a deterministic verdict. See docs/test-verdict-model.md.",
  "type": "object",
  "required": [
    "id",
    "title",
    "timeout_ms",
    "assertions"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "prerequisites": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "board": {
          "type": "string"
        },
        "probe": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3600000
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "source",
          "expression",
          "operator",
          "expected"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "enum": [
              "variable",
              "register",
              "memory",
              "target_state",
              "practice_state",
              "message",
              "breakpoint_hit",
              "cmm_return",
              "terminal_line"
            ]
          },
          "expression": {
            "type": "string",
            "minLength": 1,
            "description": "Read-only TRACE32 function text, e.g. Var.VALUE(g_state) or Register(PC)."
          },
          "operator": {
            "type": "string",
            "enum": [
              "eq",
              "ne",
              "lt",
              "le",
              "gt",
              "ge",
              "in",
              "contains",
              "matches"
            ]
          },
          "expected": {
            "description": "Expected value. Any JSON type; compared per operator."
          },
          "tolerance": {
            "type": "number",
            "minimum": 0,
            "description": "Optional absolute tolerance for numeric comparisons."
          },
          "dry_run_actual": {
            "description": "Optional injected actual value used only in --dry-run for deterministic self-tests."
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "capture_message": {
          "type": "boolean",
          "default": true
        },
        "capture_area": {
          "type": "boolean",
          "default": false
        },
        "capture_window": {
          "type": [
            "string",
            "null"
          ]
        },
        "write_json_log": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "teardown": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional cleanup. Any target-mutating teardown requires a board-approved runbook.",
      "properties": {
        "note": {
          "type": "string"
        },
        "requires_board_approval": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
