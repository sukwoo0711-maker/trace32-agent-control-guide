{
  "version": "2026-07-06",
  "classes": {
    "observe": {
      "description": "Read-only or evidence-producing operations.",
      "examples": [
        "PRINT",
        "AREA",
        "OPEN",
        "WRITE",
        "CLOSE",
        "Var.PRINT",
        "Var.WRITE",
        "Var.EXPORT",
        "Register(...)",
        "Var.VALUE(...)",
        "STATE.RUN()",
        "FOUND()",
        "FILE.EOF()"
      ]
    },
    "bounded_control": {
      "description": "Execution control allowed only with explicit timeout and evidence.",
      "examples": [
        "WAIT",
        "Go",
        "Break",
        "Step",
        "Break.Set",
        "Break.Delete",
        "Break.List",
        "Var.Break.Set",
        "Var.Watch",
        "Var.AddWatch"
      ]
    },
    "practice_flow": {
      "description": "PRACTICE flow and macro commands allowed in examples.",
      "examples": [
        "ENDDO",
        "DO",
        "ENTRY",
        "PARAMETERS",
        "LOCAL",
        "PRIVATE",
        "IF",
        "ELSE",
        "RePeaT",
        "WHILE",
        "GOTO",
        "GOSUB",
        "RETURN"
      ]
    },
