      "examples": [
        "SYStem.*",
        "SYStem.Up",
        "SYStem.Down",
        "SYStem.RESet",
        "RESet",
        "Data.LOAD.*",
        "Data.Set",
        "Register.Set",
        "Register.* writes",
        "Var.set",
        "FLASH.*",
        "TrOnchip.*",
        "CORE.*",
        "MAP.*",
        "MMU.*",
        "TRANSlation.*",
        "TERM.Out",
        "TASK.CONFIG",
        "DIALOG.*",
        "ENTER",
        "PAUSE",
        "STOP",
        "SCREEN.WAIT"
      ]
    }
  }
}

